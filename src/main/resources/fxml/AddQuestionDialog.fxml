<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" prefViewportHeight="550.0" style="-fx-background-color: transparent; -fx-control-inner-background: transparent;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="moodleviewer.AddQuestionDialogController">
   <content>
      <VBox spacing="15.0">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <GridPane hgap="10.0" vgap="10.0">
              <columnConstraints>
                <ColumnConstraints minWidth="150.0" prefWidth="150.0" />
                <ColumnConstraints hgrow="ALWAYS" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <Label fx:id="lblType" style="-fx-font-weight: bold; -fx-text-fill: #495057;" GridPane.rowIndex="0" />
                  <ComboBox fx:id="typeComboBox" maxWidth="1.7E308" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                  
                  <Label fx:id="lblName" style="-fx-font-weight: bold; -fx-text-fill: #495057;" GridPane.rowIndex="1" />
                  <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  
                  <Label fx:id="lblText" style="-fx-font-weight: bold; -fx-text-fill: #495057;" GridPane.rowIndex="2" />
                  <TextArea fx:id="textField" prefRowCount="3" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  
                  <Label fx:id="lblGrade" style="-fx-font-weight: bold; -fx-text-fill: #495057;" GridPane.rowIndex="3" />
                  <TextField fx:id="defaultGradeField" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                  
                  <Label fx:id="lblPenalty" style="-fx-font-weight: bold; -fx-text-fill: #495057;" GridPane.rowIndex="4" />
                  <TextField fx:id="penaltyField" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                  
                  <Label fx:id="lblGeneralFeedback" style="-fx-font-weight: bold; -fx-text-fill: #495057;" GridPane.rowIndex="5" />
                  <TextArea fx:id="feedbackField" prefRowCount="2" GridPane.columnIndex="1" GridPane.rowIndex="5" />
               </children>
            </GridPane>
            <Separator />
            <VBox fx:id="specificSettingsContainer" spacing="15.0" />
         </children>
      </VBox>
   </content>
</ScrollPane>